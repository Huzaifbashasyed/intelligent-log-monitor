link1:http://localhost:8080/api/logs
// it will show all logs

link2:http://localhost:8080/api/logs/{service}
// it will show logs for a specific service

link3:http://localhost:8080/api/logs/{service}/{level}
// it will show logs for a specific service and level

link4:http://localhost:8080/api/logs/{service}/{level}/{duration}
// it will show logs for a specific service and level and duration

link5:http://localhost:8080/api/logs/{service}/{level}/{duration}/{message}
// it will show logs for a specific service and level and duration and message

link6: http://localhost:5178/
// it will show the dashboard

link7: http://localhost:5178/api/logs
// it will show all logs

